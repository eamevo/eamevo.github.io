---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Enam Amevo" currentPage="home">
  <section id="top" class="hero">
    <div id="hero-overlay">
      <div class="hero-text">
        <h1>Enam S. Amevo</h1>
        <h2>Electrical Engineering @ Georgia Tech</h2>
        <p>Specializing in Circuit Technology & Signal Processing</p>
        <br>
        <a href="https://linkedin.com/in/eamevo" class="btn">Let's Connect on LinkedIn!</a>
      </div>
    </div>
  </section>

  <section id="about" style="padding: 40px 20px;">
    <h2 class="heading">ABOUT</h2>
    <p>
      I am a 3rd year Electrical Engineering student at the Georgia Institute of Technology. My threads are in Circuit Technology and Signal Processing! My focus is on integrated system design, bridging the gap between Physical Circuits (AMS), Digital Logic (VLSI, especially digital design), and Low-Level Software (Embedded Systems).
    </p>
  </section>

  <div id="education" class="background-alt">
    <h2 class="heading">Education</h2>
    <div id="education-timeline">
      <div data-date="Dec 2027 (Expected)">
        <h3>Georgia Institute of Technology</h3>
        <h4>B.S. Electrical Engineering</h4>
        <p>Minoring in Materials Science & Engineering</p>
      </div>
    </div>
  </div>

  <div id="skills">
    <h2 class="heading">Hardware & Programming</h2>
    <ul>
      <li>SystemVerilog/Verilog</li>
      <li>VHDL</li>
      <li>C/C++</li>
      <li>CUDA/MPI</li>
      <li>MATLAB</li>
      <li>Cadence/Synopsys</li>
      <li>PCB Design</li>
      <li>FPGA</li>
    </ul>
  </div>
</Layout>
