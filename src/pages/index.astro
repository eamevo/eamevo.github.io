---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Enam Amevo" currentPage="home">
  <section id="top" class="hero">
    <div class="hero-text">
      <h1>Enam S. Amevo</h1>
      <h2>Electrical Engineering @ Georgia Tech</h2>
      <p>Circuit Technology · Signal Processing · VLSI</p>
      <br>
      <a href="/about" class="btn">Learn More About Me</a>
      <div class="hero-social">
        <a href="https://linkedin.com/in/eamevo" target="_blank" rel="noopener noreferrer">
          <img src="/assets/img/icons/LinkedIn.png" alt="LinkedIn"></a>
        <a href="https://github.com/eamevo" target="_blank" rel="noopener noreferrer">
          <img src="/assets/img/icons/GitHub.png" alt="GitHub"></a>
        <a href="mailto:eamevo3@gatech.edu">
            <img src="/assets/img/icons/Mail.png" alt="Email"></a>
      </div>
    </div>
  </section>

  <section class="home-cta">
    <h2 class="heading">Explore</h2>
    <div class="cta-grid">
      <a href="/experience" class="cta-card cta-card-red">
        <span class="cta-card-icon">&#9889;</span>
        <h3>Experience</h3>
        <p>Research and Internships</p>
      </a>
      <a href="/projects" class="cta-card cta-card-blue">
        <span class="cta-card-icon">&#9881;</span>
        <h3>Projects</h3>
        <p>Technical Exploration! Real Hands-On Work Experience! :)</p>
      </a>
      <a href="/resume" class="cta-card cta-card-yellow">
        <span class="cta-card-icon">&#9998;</span>
        <h3>Resume</h3>
        <p>My resume, as of March 17, 2026.</p>
      </a>
    </div>
  </section>

  <section class="home-currently">
    <h2 class="heading">Currently</h2>
    <div class="currently-items">
      <div class="currently-item">
        <strong>Incoming</strong>
        SoC Integration RTL Intern at Marvell Technology, Summer 2026
      </div>
      <div class="currently-item">
        <strong>VIP</strong>
        Retrofuturistic Hardware under Dr. Aaron Lanterman &middot; 6502/65c816 &middot; XMOS
      </div>
      <div class="currently-item">
        <strong>Research</strong>
        Undergraduate Research Assistant at GarTen Lab and Plasma and Dielectrics Lab
      </div>
    </div>
  </section>
</Layout>