---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={`${project.data.title} | Enam Amevo`} currentPage="projects">
  <article class="project-post">
    <header class="project-post-header">
      <a href="/projects" class="back-link">&lt; Back to Projects</a>
      <h1>{project.data.title}</h1>
      {project.data.image && (
        <div class="project-post-hero">
          <img src={project.data.image} alt={project.data.title} />
        </div>
      )}
      <div class="project-post-meta">
        <span class="project-date">
          {project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
        <div class="tags">
          {project.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
      {project.data.links && project.data.links.some((l: {label: string, url: string}) => l.url) && (
        <div class="project-post-links">
          {project.data.links.filter((l: {label: string, url: string}) => l.url).map((link: {label: string, url: string}) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="project-link">
              {link.label} &#8599;
            </a>
          ))}
        </div>
      )}
    </header>
    <div class="project-post-body">
      <Content />
    </div>
  </article>
</Layout>